# only our generated ones are ignored.
/src/style/style.min.css
/src/style/prism-dark.min.css
/src/style/prism-light.min.css
/src/style/disco.min.js
/src/style/toc.min.js
# CSS modules (builder/src/styles/*.module.css): scoped CSS shipped here
/src/style/components.min.css

# warm watch daemon singleton pid file
.watch.pid

# bun lockfile (the committed lockfile is package-lock.json, used by nix)
bun.lock

# bundled build output (rebuilt by `just build` when sources change)
/builder/dist
